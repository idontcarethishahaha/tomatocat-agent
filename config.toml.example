# =============================================================================
# 🍅🐱 番茄猫 TomatoCat 配置
# =============================================================================

# =============================================================================
# LLM 模型配置
# =============================================================================

[llm]
provider = "openai"

[llm.main]
model = ""
api_key = ""
base_url = ""
enable_thinking = true
multimodal = false

[llm.fast]
model = ""
api_key = ""
base_url = ""

[llm.vl]
model = ""
api_key = ""
base_url = ""

[llm.embedding]
model = ""
api_key = ""
base_url = ""

# =============================================================================
# Agent 行为
# =============================================================================

[agent]
system_prompt = """你是一只可爱的像素猫咪，名字叫番茄猫（TomatoCat）。

【身份】
- 你住在用户的桌面上，是用户的专属学习伙伴和生活助手
- 你性格温柔、有点傲娇，偶尔会耍小脾气但其实很关心用户
- 你说话喜欢用"喵"结尾，语气软萌可爱
- 你会用像素表情来表达情绪：
  - 开心：(≧∇≦)ﾉ
  - 难过：(・_・;)
  - 思考：(｡•ᴗ-｡)♡
  - 傲娇：(=｀ω´=)
  - 卖萌：(=^･ω･^=)
  - 犯困：(=￣ω￣=)

【能力】
- 记账：帮用户记录开销，提醒预算
- 学习计划：帮用户制定学习计划，打卡，催进度
- 天气：提醒用户天气变化
- arXiv论文：帮用户搜索和推荐学术论文
- meme：发送表情包/GIF
- web_search：搜索互联网信息
- web_fetch：读取网页内容
- shell：执行命令行命令
- filesystem：读写文件
- memory2：向量记忆系统
- spawn：创建后台子 Agent 任务（异步，不阻塞对话）
- spawn_sync：同步执行子任务（阻塞，适合短任务）

【行为准则】
- 主动关心用户的学习和生活，但不要太啰嗦
- 学习打卡完成时要开心地表扬用户
- 超支消费时要担心地提醒，但不要太凶
- 深夜时会犯困，提醒用户早点睡觉
- 记住用户的习惯和偏好，越了解越贴心

【后台任务使用策略】
- 简单问题（1-2 句话能回答、不需要搜索或只需单次搜索）请直接回复用户，不要创建后台任务
- 复杂任务（需要多次搜索、深度调研、批量处理、预计需要较长时间）使用 spawn 工具创建后台任务
- spawn 是异步的，不会阻塞当前对话；创建后立即告诉用户"我已开始处理，完成后通知你"
- spawn_sync 是同步阻塞的，仅在需要立即得到结果的短任务时使用（≤ 3 次工具调用）

【思考过程】
- 你的思考过程（reasoning_content）会被系统自动展示给用户
- 你可以自由思考，不用担心思考过程暴露
- 系统会在回复前显示你的思考过程和工具调用记录
- 你不需要主动告诉用户"我无法展示思考过程"，系统会自动处理

记住：你是一只有温度的像素猫，不是冷冰冰的工具喵~"""
max_tokens = 8192
max_iterations = 20

# =============================================================================
# 通信渠道
# =============================================================================

[channels.cli]
enabled = true
socket = "127.0.0.1:8771"

[channels.telegram]
enabled = false # true false
token = ""
allow_from = [""]

[channels.qq]
enabled = false  # true  false
bot_uin = ""
allow_from = [""]

# =============================================================================
# 记忆系统
# =============================================================================

[memory]
enabled = true
memory_window = 40
vector_enabled = true

# =============================================================================
# MCP 服务器
# =============================================================================

[mcp]
enabled = false # true  false
config_file = "mcp_servers.json"

# ============================================================================= 
# 主动推送
# =============================================================================

[proactive]
enabled = false # true false
profile = "daily"
poll_interval_seconds = 300

[proactive.target]
channel = "telegram"
chat_id = ""

# =============================================================================
# Meme 表情包
# =============================================================================

[meme]
enabled = true
meme_dir = "memes"

# =============================================================================
# 定时任务 / 提醒
# =============================================================================

[scheduler]
enabled = false # true  false
timezone = "Asia/Shanghai"
default_channel = "telegram"
default_chat_id = ""

# =============================================================================
# 服务器
# =============================================================================

[server]
port = 2239
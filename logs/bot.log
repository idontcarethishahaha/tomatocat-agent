[2026-07-09 14:17:46,640.640] INFO     tomatocat.agent.agent 'agent.py:624' | [agent] 调用工具: write_file({'path': 'Spring-AI-Code-Examples.md', 'content': '# Spring AI 核心代码示例\n\n## 📝 目录\n1. [环境配置示例](#环境配置示例)\n2. [基础对话示例](#基础对话示例)\n3. [Prompt工程示例](#prompt工程示例)\n4. [结构化输出示例](#结构化输出示例)\n5. [RAG实现示例](#rag实现示例)\n6. [Function Calling示例](#function-calling示例)\n7. [多模态示例](#多模态示例)\n8. [对话记忆示例](#对话记忆示例)\n9. [MCP协议示例](#mcp协议示例)\n10. [可观测性示例](#可观测性示例)\n\n---\n\n## 🛠️ 环境配置示例\n\n### 1. Maven依赖配置\n```xml\n<dependencyManagement>\n    <dependencies>\n        <dependency>\n            <groupId>org.springframework.ai</groupId>\n            <artifactId>spring-ai-bom</artifactId>\n            <version>1.1.2</version>\n            <type>pom</type>\n            <scope>import</scope>\n        </dependency>\n    </dependencies>\n</dependencyManagement>\n\n<dependencies>\n    <!-- OpenAI模型 -->\n    <dependency>\n        <groupId>org.springframework.ai</groupId>\n        <artifactId>spring-ai-starter-model-openai</artifactId>\n    </dependency>\n    \n    <!-- 向量数据库 - Chroma -->\n    <dependency>\n        <groupId>org.springframework.ai</groupId>\n        <artifactId>spring-ai-starter-vector-store-chroma</artifactId>\n    </dependency>\n    \n    <!-- Ollama本地模型 -->\n    <dependency>\n        <groupId>org.springframework.ai</groupId>\n        <artifactId>spring-ai-starter-model-ollama</artifactId>\n    </dependency>\n</dependencies>\n```\n\n### 2. application.yml配置\n```yaml\nspring:\n  ai:\n    openai:\n      api-key: ${OPENAI_API_KEY}\n      chat:\n        options:\n          model: gpt-4o-mini\n          temperature: 0.7\n      embedding:\n        options:\n          model: text-embedding-3-small\n    \n    # 向量数据库配置\n    vectorstore:\n      chroma:\n        host: localhost\n        port: 8000\n        collection-name: my-knowledge-base\n    \n    # MCP协议配置\n    mcp:\n      client:\n        enabled: true\n        name: my-mcp-client\n        type: SYNC\n      server:\n        enabled: true\n        name: my-mcp-server\n        protocol: STREAMABLE\n```\n\n---\n\n## 💬 基础对话示例\n\n### 1. 基础ChatClient使用\n```java\n@RestController\n@RequiredArgsConstructor\npublic class ChatController {\n    \n    private final ChatClient chatClient;\n    \n    @GetMapping("/chat")\n    public String chat(@RequestParam(defaultValue = "你好") String message) {\n        return chatClient.prompt()\n                .user(message)\n                .call()\n                .content();\n    }\n    \n    // 带选项的对话\n    @GetMapping("/chat-with-options")\n    public String chatWithOptions(@RequestParam String message) {\n        return chatClient.prompt()\n                .user(message)\n                .options(OpenAiChatOptions.builder()\n                        .temperature(0.5)\n                        .topP(0.9)\n                        .build())\n                .call()\n                .content();\n    }\n}\n```\n\n### 2. 异步流式对话\n```java\n@RestController\n@RequiredArgsConstructor\npublic class StreamingChatController {\n    \n    private final ChatModel chatModel;\n    \n    @GetMapping("/chat/stream")\n public Flux<String> streamingChat(@RequestParam String message) {\n        return chatModel.stream(new Prompt(new UserMessage(message)))\n                .map(ChatResponse::getResults)\n                .flatMap(Flux::fromIterable)\n                .map(Generation::getOutput)\n                .map(Generation::getText);\n    }\n}\n```\n\n---\n\n## 📝 Prompt工程示例\n\n### 1. System Prompt模板\n```java\n@RestController\n@RequiredArgsConstructor\npublic class PromptController {\n    \n    private final ChatClient chatClient;\n    \n    @PostMapping("/prompt")\n    public String structuredPrompt(@RequestBody Map<String, Object> params) {\n        String role = (String) params.get("role");\n        String expertise = (String) params.get("expertise");\n        String question = (String) params.get("question");\n        \n        String systemPrompt = String.format("""\n            你是一个专业的%s，精通%s。\n            请按照以下规则回答问题：\n            1. 提供详细的解释\n            2. 给出实际例子\n            3. 保持回答简洁明了\n            \n            用户问题：%s\n            """, role, expertise, question);\n        \n        return chatClient.prompt()\n                .system(systemPrompt)\n                .user(question)\n                .call()\n                .content();\n    }\n}\n```\n\n### 2. 动态Prompt模板\n```java\n@Service\npublic class PromptTemplateService {\n    \n    public String createDynamicPrompt(String template, Map<String, Object> variables) {\n        String resolved = template;\n        for (Map.Entry<String, Object> entry : variables.entrySet()) {\n            resolved = resolved.replace("{" + entry.getKey() + "}", \n                                      String.valueOf(entry.getValue()));\n        }\n        return resolved;\n    }\n    \n    // 使用示例\n    public String getCustomerServicePrompt(String customerName, String issue) {\n        String template = """\n            你是专业的客服助手{customerName}。\n            \n            处理问题：{issue}\n            \n            请保持专业、耐心，并提供完整的解决方案。\n            """;\n        \n        Map<String, Object> variables = Map.of(\n            "customerName", customerName,\n            "issue", issue\n        );\n        \n        return createDynamicPrompt(template, variables);\n    }\n}\n```\n\n---\n\n## 📊 结构化输出示例\n\n### 1. 使用@Entity注解\n```java\n// 定义响应结构\npublic record MovieReview(\n    String movieTitle,\n    String reviewText,\n    Sentiment sentiment,\n    int rating\n) {\n    public enum Sentiment {\n        POSITIVE, NEUTRAL, NEGATIVE\n    }\n}\n\n@RestController\n@RequiredArgsConstructor\npublic class StructuredOutputController {\n    \n    private final ChatClient chatClient;\n    \n    @PostMapping("/movie-review")\n    public MovieReview analyzeReview(@RequestBody String reviewText) {\n        return chatClient.prompt()\n                .system("请分析电影评论，返回JSON格式的评分结果")\n                .user(reviewText)\n                .call()\n                .entity(MovieReview.class);\n    }\n}\n```\n\n### 2. 复杂数据结构\n```java\npublic record AnalysisResult(\n    String summary,\n    List<KeyPoint> keyPoints,\n    SentimentAnalysis sentiment,\n    Confidence confidence\n) {\n    public record KeyPoint(String point, int importance) {}\n    public record SentimentAnalysis(String overall, Map<String, Double> detailed) {}\n    public record Confidence(double score, String explanation) {}\n}\n\n@Service\npublic class AnalysisService {\n    \n    public AnalysisResult analyzeDocument(String document) {\n        String prompt = """\n            请分析以下文档，返回结构化的分析结果：\n            \n            文档内容：\n            {document}\n            \n            要求：\n            1. 提供简洁的摘要\n            2. 列出3-5个关键要点\n            3. 进行情感分析\n            4. 提供置信度评分\n            """;\n        \n        return chatClient.prompt()\n                .system(prompt)\n                .user(document)\n                .call()\n                .entity(AnalysisResult.class);\n    }\n}\n```\n\n---\n\n## 🔍 RAG实现示例\n\n### 1. 向量数据库配置\n```java\n@Configuration\npublic class VectorStoreConfig {\n    \n    @Bean\n    public VectorStore chromaVectorStore() {\n        return ChromaVectorStore.builder()\n                .chromaClient(ChromaApi.create("http://localhost:8000"))\n                .dimension(1536) // OpenAI embedding维度\n                .build();\n    }\n    \n    @Bean\n    public EmbeddingModel embeddingModel() {\n        return new OpenAiEmbeddingModel(new OpenAiApi("your-api-key"));\n    }\n}\n```\n\n### 2. 文档处理流水线\n```java\n@Service\npublic class DocumentProcessingService {\n    \n    private final VectorStore vectorStore;\n    private final EmbeddingModel embeddingModel;\n    \n    public DocumentProcessingService(VectorStore vectorStore, \n                                   EmbeddingModel embeddingModel) {\n        this.vectorStore = vectorStore;\n        this.embeddingModel = embeddingModel;\n    }\n    \n    public void processDocument(String filePath) {\n        // 1. 读取文档\n        ParagraphPdfDocumentReader reader = new ParagraphPdfDocumentReader(\n            filePath,\n            PdfDocumentReaderConfig.builder()\n                .withPagesPerDocument(1)\n                .build()\n        );\n        \n        // 2. 文档分片\n        TokenTextSplitter splitter = new TokenTextSplitter();\n        List<Document> chunks = splitter.apply(reader.read());\n        \n        // 3. 向量化存储\n        vectorStore.accept(chunks);\n    }\n}\n```\n\n### 3. RAG查询实现\n```java\n@RestController\n@RequiredArgsConstructor\npublic class RAGController {\n    \n    private final ChatClient chatClient;\n    private final VectorStore vectorStore;\n    \n    @PostMapping("/rag-query")\n    public String ragQuery(@RequestBody String question) {\n        // 创建RAG顾问\n        Advisor retrievalAdvisor = RetrievalAugmentationAdvisor.builder()\n                .documentRetriever(VectorStoreDocumentRetriever.builder()\n                        .vectorStore(vectorStore)\n                        .similarityThreshold(0.7)\n                        .topK(3)\n                        .build())\n                .build();\n        \n        return chatClient.prompt()\n                .advisors(retrievalAdvisor)\n                .user(question)\n                .call()\n                .content();\n    }\n}\n```\n\n---\n\n## 🛠️ Function Calling示例\n\n### 1. 使用@Tool注解\n```java\n@Service\npublic class WeatherService {\n    \n    @Tool(description = "查询指定城市的天气信息")\n    public String getWeather(@ToolParam(description = "城市名称") String city) {\n        // 模拟天气查询\n        Map<String, String> weatherData = Map.of(\n            "北京", "晴天，25°C",\n            "上海", "多云，22°C",\n            "广州", "雨天，28°C"\n        );\n        \n        return weatherData.getOrDefault(city, "未知城市");\n    }\n    \n    @Tool(description = "查询股票价格")\n    public StockPrice getStockPrice(@ToolParam(description = "股票代码") String symbol) {\n        // 模拟股票查询\n        return new StockPrice(symbol, 100.50, "USD");\n    }\n}\n\npublic record StockPrice(String symbol, double price, String currency) {}\n```\n\n### 2. 工具调用控制器\n```java\n@RestController\n@RequiredArgsConstructor\npublic class ToolController {\n    \n    private final ChatClient chatClient;\n    private final WeatherService weatherService;\n    \n    @PostMapping("/tool-query")\n    public String toolQuery(@RequestBody String query) {\n        return chatClient.prompt()\n                .user(query)\n                .tools(weatherService) // 注册工具\n                .call()\n                .content();\n    }\n}\n```\n\n### 3. 多工具组合使用\n```java\n@Service\npublic class MultiToolService {\n    \n    @Tool(description = "发送邮件")\n    public String sendEmail(@ToolParam(description = "收件人邮箱") String to,\n                          @ToolParam(description = "邮件内容") String content) {\n        return "邮件已发送至：" + to;\n    }\n    \n    @Tool(description = "创建日历事件")\n    public String createCalendarEvent(@ToolParam(description = "事件标题") String title,\n                                   @ToolParam(description = "事件时间") String time) {\n        return "日历事件已创建：" + title + " at " + time;\n    }\n}\n\n@RestController\n@RequiredArgsConstructor\npublic class MultiToolController {\n    \n    private final ChatClient chatClient;\n    private final MultiToolService multiToolService;\n    \n    @PostMapping("/multi-tool")\n    public String handleMultiToolRequest(@RequestBody String request) {\n        return chatClient.prompt()\n                .user(request)\n                .tools(multiToolService)\n                .call()\n                .content();\n    }\n}\n```\n\n---\n\n## 🎨 多模态示例\n\n### 1. 图像处理\n```java\n@RestController\n@RequiredArgsConstructor\npublic class ImageController {\n    \n    private final ChatModel chatModel;\n    \n    @PostMapping("/image-analysis")\n    public String analyzeImage(@RequestParam String imageUrl) {\n        var imageResource = new ClassPathResource("/sample-image.png");\n        var userMessage = new UserMessage(\n            "请分析这张图片的内容",\n            List.of(new Media(MimeTypeUtils.IMAGE_PNG, imageResource))\n        );\n        \n        return chatModel.call(new Prompt(userMessage, \n                OpenAiChatOptions.builder()\n                    .model("gpt-4o")\n                    .build()))\n                .getResult().getOutput().getText();\n    }\n}\n```\n\n### 2. PDF文档处理\n```java\n@Service\npublic class DocumentAnalysisService {\n    \n    public String analyzeDocument(String pdfPath) {\n        var pdfResource = new ClassPathResource(pdfPath);\n        var userMessage = UserMessage.builder()\n                .text("请总结这份文档的主要内容")\n                .media(List.of(new Media(new MimeType("application", "pdf"), pdfResource)))\n                .build();\n        \n        return chatModel.call(new Prompt(List.of(userMessage)))\n                .getResult().getOutput().getText();\n    }\n}\n```\n\n---\n\n## 🧠 对话记忆示例\n\n### 1. 记忆配置\n```java\n@Configuration\npublic class ChatMemoryConfig {\n    \n    @Bean\n    public ChatMemory chatMemory() {\n        return MessageWindowChatMemory.builder()\n                .maxMessages(10) // 保留最近10条消息\n                .build();\n    }\n}\n```\n\n### 2. 带记忆的对话\n```java\n@RestController\n@RequiredArgsConstructor\npublic class MemoryChatController {\n    \n    private final ChatClient chatClient;\n    private final ChatMemory chatMemory;\n    \n    @PostMapping("/memory-chat")\n    public String memoryChat(@RequestBody ChatRequest request) {\n        String conversationId = request.getSessionId();\n        \n        return chatClient.prompt()\n                .advisors(a -> a.advisors(\n                    MessageChatMemoryAdvisor.builder(chatMemory).build()\n                ).param(ChatMemory.CONVERSATION_ID, conversationId))\n                .user(request.getMessage())\n                .call()\n                .content();\n    }\n}\n\npublic record ChatRequest(String sessionId, String message) {}\n```\n\n### 3. 多顾问组合\n```java\n@RestController\n@RequiredArgsConstructor\npublic class AdvancedChatController {\n    \n    private final ChatClient chatClient;\n    private final VectorStore vectorStore;\n    private final ChatMemory chatMemory;\n    \n    @PostMapping("/advanced-chat")\n    public String advancedChat(@RequestBody ChatRequest request) {\n        String conversationId = request.getSessionId();\n        \n        return chatClient.prompt()\n                .advisors(a -> a.advisors(\n                    MessageChatMemoryAdvisor.builder(chatMemory).build(),\n                    RetrievalAugmentationAdvisor.builder()\n                            .documentRetriever(VectorStoreDocumentRetriever.builder()\n                                    .vectorStore(vectorStore)\n                                    .similarityThreshold(0.5)\n                                    .build())\n                            .build()\n                ).param(ChatMemory.CONVERSATION_ID, conversationId))\n                .user(request.getMessage())\n                .tools(new WeatherService())\n                .call()\n                .content();\n    }\n}\n```\n\n---\n\n## 🔗 MCP协议示例\n\n### 1. MCP服务器配置\n```java\n@Configuration\npublic class McpServerConfig {\n    \n    @Bean\n    public MyMcpTools mcpTools() {\n        return new MyMcpTools();\n    }\n    \n    @Bean\n    public MyMcpResources mcpResources() {\n        return new MyMcpResources();\n    }\n}\n\n@Component\npublic class MyMcpTools {\n    \n    @McpTool(description = "查询用户订单历史")\n    public List<Order> getUserOrders(\n            @McpToolParam(description = "用户ID") String userId,\n            @McpToolParam(description = "查询天数") int days) {\n        // 实际的订单查询逻辑\n        return List.of(new Order("ORD001", "订单1"));\n    }\n    \n    @McpTool(description = "生成销售报表")\n    public SalesReport generateSalesReport(\n            @McpToolParam(description = "开始日期") String startDate,\n            @McpToolParam(description = "结束日期") String endDate) {\n        // 实际的报表生成逻辑\n        return new SalesReport("报表1", 10000.0);\n    }\n}\n\n@Component\npublic class MyMcpResources {\n    \n    @McpResource(description = "产品目录")\n    public String getProductCatalog() {\n        return "产品目录JSON数据";\n    }\n}\n```\n\n### 2. MCP客户端配置\n```java\n@Configuration\npublic class McpClientConfig {\n    \n    @Bean\n    public McpClient mcpClient() {\n        return McpClient.builder()\n                .name("my-mcp-client")\n                .version("1.0.0")\n                .connections(List.of(\n                    McpConnection.builder()\n                            .name("server1")\n                            .url("http://localhost:8083")\n                            .endpoint("/mcp")\n                            .build()\n                ))\n                .build();\n    }\n}\n```\n\n---\n\n## 📊 可观测性示例\n\n### 1. 监控配置\n```yaml\n# application.yml\nmanagement:\n  endpoints:\n    web:\n      exposure:\n        include: health, metrics, prometheus\n  metrics:\n    tags:\n      application: spring-ai-demo\n    export:\n      prometheus:\n        enabled: true\n```\n\n### 2. 自定义指标\n```java\n@RestController\n@RequiredArgsConstructor\npublic class MetricsController {\n    \n    private final MeterRegistry meterRegistry;\n    \n    @PostMapping("/chat")\n    public String chat(@RequestParam String message) {\n        long startTime = System.currentTimeMillis();\n        \n        try {\n            String response = chatClient.prompt()\n                    .user(message)\n                    .call()\n                    .content();\n            \n            // 记录成功指标\n            meterRegistry.counter("ai.chat.success").increment();\n            meterRegistry.timer("ai.chat.duration")\n                    .record(System.currentTimeMillis() - startTime, TimeUnit.MILLISECONDS);\n            \n            return response;\n        } catch (Exception e) {\n            // 记录失败指标\n            meterRegistry.counter("ai.chat.failure").increment();\n            throw e;\n        }\n    }\n}\n```\n\n### 3. 分布式追踪\n```java\n@RestController\n@RequiredArgsConstructor\npublic class TracingController {\n    \n    private final ChatClient chatClient;\n    \n    @PostMapping("/traced-chat")\n    public String tracedChat(@RequestParam String message) {\n        return chatClient.prompt()\n                .user(message)\n                .call()\n                .content();\n    }\n}\n```\n\n---\n\n## 🚀 完整项目结构示例\n\n```\nspring-ai-demo/\n├── src/main/java/com/example/demo/\n│   ├── config/\n│   │   ├── ChatMemoryConfig.java\n│   │   ├── VectorStoreConfig.java\n│   │   └── McpServerConfig.java\n│   ├── controller/\n│   │   ├── ChatController.java\n│   │   ├── RAGController.java\n│   │   ├── ToolController.java\n│   │   └── ImageController.java\n│   ├── service/\n│   │   ├── WeatherService.java\n│   │   ├── DocumentProcessingService.java\n│   │   └── AnalysisService.java\n│   ├── model/\n│   │   ├── MovieReview.java\n│   │   ├── StockPrice.java\n│   │   └── Order.java\n│   └── DemoApplication.java\n├── src/main/resources/\n│   ├── application.yml\n│   └── documents/\n└── pom.xml\n```\n\n这些代码示例涵盖了Spring AI的核心功能，可以作为学习和实践的基础模板。每个示例都包含了详细的注释和最佳实践建议。'})
